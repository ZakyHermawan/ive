# CHECK:           %[[CONSTANT_0:.*]] = ive.constant dense<1.000000e+00> : tensor<f64>
# CHECK:           %[[CONSTANT_1:.*]] = ive.constant dense<2.000000e+00> : tensor<f64>
# CHECK:           ive.if %[[CONSTANT_0]] {
# CHECK:             ive.print %[[CONSTANT_0]] : tensor<f64>
# CHECK:             "ive.yield"() : () -> ()
# CHECK:           } else {
# CHECK:             ive.print %[[CONSTANT_1]] : tensor<f64>
# CHECK:             "ive.yield"() : () -> ()
# CHECK:           }
# CHECK:           ive.if %[[CONSTANT_1]] {
# CHECK:             ive.print %[[CONSTANT_1]] : tensor<f64>
# CHECK:             "ive.yield"() : () -> ()
# CHECK:           }
# CHECK:           ive.return
# CHECK:         }
def main() {
  var a = 1;
  var b = 2;
  if a {
    print(a);
  }
  else {
    print(b);
  }

  if (b) {
    print(b);
  }
}
